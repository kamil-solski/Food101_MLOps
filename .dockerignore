# ── Version control ──────────────────────────────────────────────────────────
.git/
.gitignore

# ── Large data / runtime-mounted volumes ─────────────────────────────────────
# Data and experiments are bind-mounted at runtime via docker-compose; never bake them in.
Data/
experiments/

# ── Notebooks (not needed by the train/serve containers) ─────────────────────
notebooks/

# ── Test suite (never runs inside service containers) ────────────────────────
tests/

# ── Python bytecode ──────────────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# ── Build / packaging artifacts ──────────────────────────────────────────────
**/*.egg-info/
.eggs/
dist/
build/

# ── Local virtual environments ───────────────────────────────────────────────
.venv/
venv/
env/

# ── Backups / scratch ────────────────────────────────────────────────────────
*.bak

# ── IDE / tooling ────────────────────────────────────────────────────────────
.vscode/
.idea/
.specstory/
.cursor/

# ── Logs ─────────────────────────────────────────────────────────────────────
**/*.log
